//@version=6
strategy(
    title="UT Shorts - High RR v8 (Dual Exit System)",
    shorttitle="UT-HRR8-DUAL",
    overlay=true,
    pyramiding=1,
    default_qty_type=strategy.percent_of_equity,
    default_qty_value=100,
    initial_capital=2600,
    commission_type=strategy.commission.percent,
    commission_value=0.05,
    process_orders_on_close=true,
    calc_on_every_tick=false
)

// === Inputs ===
enableEntries = input.bool(true, "Enable live entries")
utUseHA       = input.bool(false, "UT use Heikin Ashi source")
utKeyVal      = input.float(1.0, "UT Key value (sensitivity)", step=0.1)
utAtrPeriod   = input.int(10, "UT ATR period", minval=1)
margin_usd    = input.float(200.0, "Margin per trade (USD)", minval=0)
leverage      = input.int(15, "Leverage (x)", minval=1)

requireHTFShort = input.bool(true, "Require HTF bearish bias")
trendTf         = input.string("240", "HTF timeframe", options=["60", "120", "240"])
htfFast         = input.int(50, "HTF fast EMA", minval=1)
htfSlow         = input.int(200, "HTF slow EMA", minval=1)
htfSlopeBars    = input.int(3, "HTF EMA slope lookback (bars)", minval=1)

useLtfTrend       = input.bool(true, "Use local EMA trend filter")
ltfFast           = input.int(20, "Local fast EMA", minval=1)
ltfSlow           = input.int(50, "Local slow EMA", minval=1)
usePullbackFilter = input.bool(true, "Require pullback into fast EMA")

useRsiFilter = input.bool(true, "Use RSI confirmation")
rsiLen       = input.int(14, "RSI length", minval=1)
rsiShortMin  = input.int(40, "Min RSI for short", minval=1, maxval=100)
rsiShortMax  = input.int(58, "Max RSI for short", minval=1, maxval=100)

useVolFilter = input.bool(false, "Use volume confirmation")
volMult      = input.float(1.2, "Volume multiplier", step=0.1, minval=0.1)

useAdxFilter = input.bool(true, "Use ADX trend strength filter")
adxLen       = input.int(14, "ADX length", minval=1)
adxMin       = input.float(16.0, "Minimum ADX", step=0.5)

atrLen         = input.int(14, "ATR length (risk)", minval=1)
stopAtrMult    = input.float(2.0, "Stop loss x ATR", step=0.1, minval=0.1)
useTakeProfit  = input.bool(false, "Use fixed take profit")
tpAtrMult      = input.float(6.0, "Take profit x ATR", step=0.1, minval=0.1)
useTrailStop   = input.bool(true, "Trail stop with UT trail")
useBreakEven   = input.bool(true, "Move stop to breakeven")
beTriggerR     = input.float(1.0, "Breakeven trigger (R)", step=0.1, minval=0.1)
trailActivateR = input.float(1.2, "Activate trailing stop at (R)", step=0.1, minval=0.1)
useUtFlipExit  = input.bool(true, "Exit on UT buy signal")
maxHoldHours   = input.float(24.0, "Max hold hours (0 = disabled)", step=0.5, minval=0)
cooldownBars   = input.int(5, "Cooldown bars after exit", minval=0)

// === HTF Trend ===
htfEmaFRaw = ta.ema(close, htfFast)

htfClose  = request.security(syminfo.tickerid, trendTf, close)
htfEmaF   = request.security(syminfo.tickerid, trendTf, htfEmaFRaw)
htfEmaS   = request.security(syminfo.tickerid, trendTf, ta.ema(close, htfSlow))
htfEmaF_p = request.security(syminfo.tickerid, trendTf, htfEmaFRaw[htfSlopeBars])

htfF0 = request.security(syminfo.tickerid, trendTf, htfEmaFRaw[0])
htfF1 = request.security(syminfo.tickerid, trendTf, htfEmaFRaw[1])
htfF2 = request.security(syminfo.tickerid, trendTf, htfEmaFRaw[2])
htfF3 = request.security(syminfo.tickerid, trendTf, htfEmaFRaw[3])
htfF4 = request.security(syminfo.tickerid, trendTf, htfEmaFRaw[4])
htfF5 = request.security(syminfo.tickerid, trendTf, htfEmaFRaw[5])
htfF6 = request.security(syminfo.tickerid, trendTf, htfEmaFRaw[6])

htfTrendConfirmed = htfF0 < htfF1 and htfF1 < htfF2 and htfF2 < htfF3 and htfF3 < htfF4 and htfF4 < htfF5 and htfF5 < htfF6

htfBear       = not requireHTFShort or (htfClose < htfEmaS and htfEmaF < htfEmaS)
htfRecovering = htfEmaF > htfEmaF_p
htfPaused     = requireHTFShort and htfRecovering

// === UT Trail ===
haTicker = ticker.heikinashi(syminfo.tickerid)
haSrc    = request.security(haTicker, timeframe.period, close)
src      = utUseHA ? haSrc : close

xATR  = ta.atr(utAtrPeriod)
nLoss = utKeyVal * xATR
var float xATRTrailingStop = na
prevStop = nz(xATRTrailingStop[1], src)
xATRTrailingStop := src > prevStop and src[1] > prevStop ? math.max(prevStop, src - nLoss) :
     src < prevStop and src[1] < prevStop ? math.min(prevStop, src + nLoss) :
     src > prevStop ? src - nLoss : src + nLoss

utEma1    = ta.ema(src, 1)
crossUp   = ta.crossover(utEma1, xATRTrailingStop)
crossDown = ta.crossover(xATRTrailingStop, utEma1)
utSellSignal = src < xATRTrailingStop and crossDown
utBuySignal  = src > xATRTrailingStop and crossUp

// === Local Trend Filters ===
ltfEmaF = ta.ema(close, ltfFast)
ltfEmaS = ta.ema(close, ltfSlow)
ltfBear = not useLtfTrend or (close < ltfEmaS and ltfEmaF < ltfEmaS)
rsiVal  = ta.rsi(close, rsiLen)
rsiOk   = not useRsiFilter or (rsiVal >= rsiShortMin and rsiVal <= rsiShortMax)
volBase = ta.sma(volume, 20)
volOk   = not useVolFilter or volume > volBase * volMult
[plusDI, minusDI, adxVal] = ta.dmi(adxLen, adxLen)
adxOk      = not useAdxFilter or adxVal >= adxMin
pullbackOk = not usePullbackFilter or high >= ltfEmaF

confirmations = htfBear and not htfPaused and htfTrendConfirmed and ltfBear and rsiOk and volOk and adxOk and pullbackOk

// === Risk ===
atr             = ta.atr(atrLen)
notional        = margin_usd * leverage
notionalRounded = math.round(notional * 100.0) / 100.0

var int   entryBar       = na
var float atrAtEntry     = na
var int   lastExitBar    = na
var label lastEntryLabel = na

secondsPerBar = timeframe.in_seconds()
maxHoldBars   = maxHoldHours > 0 ? int(math.ceil(maxHoldHours * 3600.0 / secondsPerBar)) : 0

// === Track exits ===
posJustClosed = strategy.position_size == 0 and strategy.position_size[1] < 0
if posJustClosed
    lastExitBar := bar_index
    entryBar    := na
    atrAtEntry  := na
    if not na(lastEntryLabel)
        label.delete(lastEntryLabel)
        lastEntryLabel := na

canTrade = (na(lastExitBar) or (bar_index - lastExitBar > cooldownBars)) and (na(lastExitBar) or bar_index != lastExitBar)

// === Entry ===
shouldEnterShort = enableEntries and utSellSignal and confirmations and canTrade and strategy.position_size == 0

if shouldEnterShort
    strategy.entry("UT-Short", strategy.short)
    entryBar   := bar_index
    atrAtEntry := atr
    if not na(lastEntryLabel)
        label.delete(lastEntryLabel)
    lastEntryLabel := label.new(bar_index, high, "UT Short\nnotional: $" + str.tostring(notionalRounded),
         xloc=xloc.bar_index, yloc=yloc.abovebar,
         style=label.style_label_down, color=color.new(color.red, 0),
         textcolor=color.white, size=size.small)
    alert("ENTRY SHORT | {{ticker}} | {{interval}} | close={{close}}", alert.freq_once_per_bar_close)

// === Exit Logic (Dual System) ===
if strategy.position_size < 0 and not na(atrAtEntry)
    entryPrice  = strategy.position_avg_price
    riskDist    = atrAtEntry * stopAtrMult
    baseStop    = entryPrice + riskDist
    tpPrice     = useTakeProfit ? entryPrice - (atrAtEntry * tpAtrMult) : na
    profitR     = riskDist > 0 ? (entryPrice - close) / riskDist : 0.0
    managedStop = baseStop

    if useBreakEven and profitR >= beTriggerR
        managedStop := math.min(managedStop, entryPrice)

    if useTrailStop and profitR >= trailActivateR
        managedStop := math.min(managedStop, xATRTrailingStop)

    finalStop = math.max(managedStop, high + syminfo.mintick)

    // TradingView exit (keeps backtest accurate)
    strategy.exit("UT-Short-Exit", "UT-Short", stop=finalStop, limit=tpPrice)

    // REAL STOP LOSS ALERT
    if close >= finalStop
        alert("EXIT SHORT - STOP LOSS | {{ticker}} | {{interval}} | close={{close}}", alert.freq_once_per_bar_close)

    // REAL TAKE PROFIT ALERT
    if not na(tpPrice) and close <= tpPrice
        alert("EXIT SHORT - TAKE PROFIT | {{ticker}} | {{interval}} | close={{close}}", alert.freq_once_per_bar_close)

// === UT Flip Exit ===
if useUtFlipExit and utBuySignal and strategy.position_size < 0
    strategy.close("UT-Short")
    alert("EXIT SHORT - UT BUY FLIP | {{ticker}} | {{interval}} | close={{close}}", alert.freq_once_per_bar_close)

// === HTF Recovery Exit ===
if htfPaused and strategy.position_size < 0
    strategy.close("UT-Short")
    alert("EXIT SHORT - HTF RECOVERY | {{ticker}} | {{interval}} | close={{close}}", alert.freq_once_per_bar_close)

// === Max Hold Exit ===
if strategy.position_size < 0 and not na(entryBar) and maxHoldBars > 0 and (bar_index - entryBar >= maxHoldBars)
    strategy.close("UT-Short")
    alert("EXIT SHORT - MAX HOLD | {{ticker}} | {{interval}} | close={{close}}", alert.freq_once_per_bar_close)

// === Visuals ===
bgcolor(htfPaused ? color.new(color.red, 90) : na)
bgcolor(not htfPaused and not htfTrendConfirmed ? color.new(color.orange, 92) : na)
plot(xATRTrailingStop, "UT Trail", color=color.orange, linewidth=2)
plot(ltfEmaS, "Local Slow EMA", color=color.new(color.blue, 50))
plotshape(utSellSignal and confirmations, "Short Entry", location=location.abovebar, style=shape.labeldown, color=color.red, size=size.tiny, text="Sell")
plotshape(utBuySignal, "UT Buy", location=location.belowbar, style=shape.labelup, color=color.green, size=size.tiny, text="Buy")
