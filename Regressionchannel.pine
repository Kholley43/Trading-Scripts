// Revamped into a sloped regression-channel strategy

//@version=6
strategy("AE Regression Channel Revamped", overlay=true, fill_orders_on_standard_ohlc=true, pyramiding=0, process_orders_on_close=true)

// Regression Channel
grpChannel = "Regression Channel"
int_len             = input.int(200, "Regression Channel Length", minval=25, group=grpChannel)
src                 = input.source(close, "Regression Source", group=grpChannel)
col_mid             = input.color(color.yellow, "Midline Colour", group=grpChannel)
dev_inner_mult      = input.float(1.75, "Inner Deviation", minval=0.1, step=0.05, group=grpChannel)
col_inner           = input.color(color.new(color.purple, 0), "Inner Rail Colour", group=grpChannel)
dev_outer_mult      = input.float(2.50, "Outer Deviation", minval=0.1, step=0.05, group=grpChannel)
col_outer           = input.color(color.new(color.blue, 0), "Outer Rail Colour", group=grpChannel)
show_channel_fill   = input.bool(true, "Show Channel Fill", group=grpChannel)

// Trade Logic
grpTrade = "Trade Logic"
bool_useSlopeFilter = input.bool(true, "Only Trade In Channel Direction?", group=grpTrade)
bool_allowCounter   = input.bool(false, "Allow Countertrend Reclaims?", group=grpTrade)
bool_useOuterTouch  = input.bool(false, "Require Outer Rail Touch?", group=grpTrade)
bool_useBodyConfirm = input.bool(true, "Require Candle Body Confirmation?", group=grpTrade)

// Risk / Exits
grpRisk = "Trade Data"
stop_atr_mult       = input.float(0.50, "Stop ATR Buffer", minval=0.0, step=0.05, group=grpRisk)
rr_mult             = input.float(2.50, "Risk Reward Multiplier", minval=0.1, step=0.1, group=grpRisk)
target_mode         = input.string("Risk Reward", "Target Mode", options=["Risk Reward", "Midline", "Opposite Inner", "Opposite Outer"], group=grpRisk)

// ATR Filtering
grpATR = "ATR Filtering"
atr_len             = input.int(14, "ATR Length", minval=1, group=grpATR)
bool_useATR         = input.bool(true, "Use ATR Filter?", group=grpATR)
atr_low_pct         = input.float(0.30, "ATR Lower Range %", minval=0.0, maxval=1.0, step=0.05, group=grpATR)
atr_high_pct        = input.float(0.70, "ATR Upper Range %", minval=0.0, maxval=1.0, step=0.05, group=grpATR)

// Live TP/SL lines
var float storedEntry = na
var float storedSL    = na
var float storedTP    = na
var line entryLine    = na
var line tpLine       = na
var line slLine       = na

f_regression_channel(_src, _length) =>
    float sumX  = 0.0
    float sumY  = 0.0
    float sumXY = 0.0
    float sumXX = 0.0

    for i = 0 to _length - 1
        float x = i
        float y = _src[_length - 1 - i]
        sumX  += x
        sumY  += y
        sumXY += x * y
        sumXX += x * x

    float denom = _length * sumXX - sumX * sumX
    float slope = denom != 0.0 ? (_length * sumXY - sumX * sumY) / denom : 0.0
    float intercept = (_length != 0 ? (sumY - slope * sumX) / _length : na)
    float basis = intercept + slope * (_length - 1)

    float residualSS = 0.0
    for i = 0 to _length - 1
        float x = i
        float y = _src[_length - 1 - i]
        float fit = intercept + slope * x
        float residual = y - fit
        residualSS += residual * residual

    float regDev = math.sqrt(residualSS / _length)
    [basis, regDev, slope]

f_pick_target(_dir, _entry, _risk, _basis, _upperInner, _lowerInner, _upperOuter, _lowerOuter) =>
    float target = na
    if target_mode == "Risk Reward"
        target := _dir > 0 ? _entry + (_risk * rr_mult) : _entry - (_risk * rr_mult)
    else if target_mode == "Midline"
        target := _basis
    else if target_mode == "Opposite Inner"
        target := _dir > 0 ? _upperInner : _lowerInner
    else
        target := _dir > 0 ? _upperOuter : _lowerOuter

    if _dir > 0 and target <= _entry
        target := _entry + (_risk * rr_mult)
    if _dir < 0 and target >= _entry
        target := _entry - (_risk * rr_mult)
    target

atrValue = ta.atr(atr_len)
atrLow   = ta.lowest(atrValue, int_len)
atrHigh  = ta.highest(atrValue, int_len)
atrMidLow  = atrLow + (atrHigh - atrLow) * atr_low_pct
atrMidHigh = atrLow + (atrHigh - atrLow) * atr_high_pct
bool_ATROK = atrValue > atrMidLow and atrValue < atrMidHigh

[basis, regDev, slope] = f_regression_channel(src, int_len)

upperInner = basis + regDev * dev_inner_mult
lowerInner = basis - regDev * dev_inner_mult
upperOuter = basis + regDev * dev_outer_mult
lowerOuter = basis - regDev * dev_outer_mult

trendUp   = slope > 0
trendDown = slope < 0
atrFilterPass = not bool_useATR or bool_ATROK

longTouch  = bool_useOuterTouch ? low <= lowerOuter : low <= lowerInner
shortTouch = bool_useOuterTouch ? high >= upperOuter : high >= upperInner

longBodyConfirm  = not bool_useBodyConfirm or (close > open and close > lowerInner)
shortBodyConfirm = not bool_useBodyConfirm or (close < open and close < upperInner)

longTrendPass  = bool_allowCounter ? true : (not bool_useSlopeFilter or trendUp)
shortTrendPass = bool_allowCounter ? true : (not bool_useSlopeFilter or trendDown)

long_condition  = atrFilterPass and longTrendPass and longTouch and close > lowerInner and longBodyConfirm
short_condition = atrFilterPass and shortTrendPass and shortTouch and close < upperInner and shortBodyConfirm

if bar_index >= int_len
    if long_condition and strategy.position_size <= 0
        entryPrice = close
        stopPrice = math.min(low, lowerOuter) - atrValue * stop_atr_mult
        riskValue = math.abs(entryPrice - stopPrice)
        tpPrice = f_pick_target(1, entryPrice, riskValue, basis, upperInner, lowerInner, upperOuter, lowerOuter)

        strategy.entry("Long", strategy.long)
        strategy.exit("Exit Long", "Long", stop=stopPrice, limit=tpPrice, comment_loss="SL " + str.tostring(stopPrice), comment_profit="TP " + str.tostring(tpPrice))

        storedEntry := entryPrice
        storedSL := stopPrice
        storedTP := tpPrice

    if short_condition and strategy.position_size >= 0
        entryPrice = close
        stopPrice = math.max(high, upperOuter) + atrValue * stop_atr_mult
        riskValue = math.abs(stopPrice - entryPrice)
        tpPrice = f_pick_target(-1, entryPrice, riskValue, basis, upperInner, lowerInner, upperOuter, lowerOuter)

        strategy.entry("Short", strategy.short)
        strategy.exit("Exit Short", "Short", stop=stopPrice, limit=tpPrice, comment_loss="SL " + str.tostring(stopPrice), comment_profit="TP " + str.tostring(tpPrice))

        storedEntry := entryPrice
        storedSL := stopPrice
        storedTP := tpPrice

if strategy.position_size == 0 and strategy.position_size[1] != 0
    storedEntry := na
    storedSL := na
    storedTP := na
    if not na(entryLine)
        line.delete(entryLine)
    if not na(tpLine)
        line.delete(tpLine)
    if not na(slLine)
        line.delete(slLine)
    entryLine := na
    tpLine := na
    slLine := na

if strategy.position_size != 0 and strategy.position_size[1] == 0
    if not na(entryLine)
        line.delete(entryLine)
    if not na(tpLine)
        line.delete(tpLine)
    if not na(slLine)
        line.delete(slLine)

    entryLine := line.new(bar_index, storedEntry, bar_index + 1, storedEntry, extend=extend.right, color=color.yellow, width=2)
    tpLine := line.new(bar_index, storedTP, bar_index + 1, storedTP, extend=extend.right, color=color.orange, width=2)
    slLine := line.new(bar_index, storedSL, bar_index + 1, storedSL, extend=extend.right, color=color.purple, width=2)

midPlot = plot(basis, color=col_mid, linewidth=2, title="Regression Midline")
upperInnerPlot = plot(upperInner, color=col_inner, linewidth=2, title="Inner Upper")
lowerInnerPlot = plot(lowerInner, color=col_inner, linewidth=2, title="Inner Lower")
upperOuterPlot = plot(upperOuter, color=col_outer, linewidth=2, title="Outer Upper")
lowerOuterPlot = plot(lowerOuter, color=col_outer, linewidth=2, title="Outer Lower")

fill(upperOuterPlot, upperInnerPlot, color=show_channel_fill ? color.new(col_outer, 82) : color.new(color.black, 100), title="Upper Outer Fill")
fill(upperInnerPlot, lowerInnerPlot, color=show_channel_fill ? color.new(col_inner, 88) : color.new(color.black, 100), title="Inner Fill")
fill(lowerInnerPlot, lowerOuterPlot, color=show_channel_fill ? color.new(col_outer, 82) : color.new(color.black, 100), title="Lower Outer Fill")

plotshape(long_condition, title="Long Signal", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.tiny, text="L")
plotshape(short_condition, title="Short Signal", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.tiny, text="S")
